          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"wallet-monolith\"}[5m])))",
          "legendFormat": "p95 {{uri}}",
